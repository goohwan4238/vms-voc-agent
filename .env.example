# VMS VOC Agent 환경 설정

# VMS Works DB (읽기 + VOC 상태 쓰기 권한 필요)
VMS_DB_URL=postgresql://user:pass@host:5433/project_management_prod

# 로컬 상태 관리용 DB
DB_URL=postgresql://vocagent:vocagent@localhost:5434/vocagent

# Redis
REDIS_URL=redis://localhost:6379

# Claude CLI
CLAUDE_CODE_PATH=claude
CLAUDE_MODEL=sonnet
CLAUDE_SOFT_TIMEOUT_MS=1800000

# VMSWorks 레포 경로 (개발/테스트 단계에서 사용)
VMSWORKS_REPO_PATH=C:/Users/chunggh/Documents/GitHub/vmsworks

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# 서버 설정
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
